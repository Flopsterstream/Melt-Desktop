{
    "layer": "top",
    "position": "top",
    "height": 40,
    "margin-top": 8,
    "margin-left": 16,
    "margin-right": 16,
    "spacing": 10,
    "modules-left": ["custom/melt", "cpu", "memory"],
    "modules-center": ["clock"],
    "modules-right": ["network", "pulseaudio", "battery"],

    "custom/melt": {
        "format": "🔥 Melt Desktop",
        "tooltip": false
    },
    "clock": {
        "format": "🕒 {:%H:%M  |  📅 %b %d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
        "format": "💻 {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "🧠 {}%"
    },
    "network": {
        "format-wifi": "🌐 {essid}",
        "format-ethernet": "🌐 Connected",
        "format-disconnected": "⚠️ Disconnected"
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "🔇 Muted",
        "format-icons": {
            "default": ["🔈", "🔉", "🔊"]
        }
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "⚡ {capacity}%",
        "format-icons": ["🔋", "🔋", "🔋", "🔋", "🔋"]
    }
}
