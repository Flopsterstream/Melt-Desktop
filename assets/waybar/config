{
    "layer": "top",
    "position": "top",
    "height": 40,
    "margin-top": 8,
    "margin-left": 16,
    "margin-right": 16,
    "spacing": 10,
    "modules-left": ["custom/melt", "wlr/taskbar", "custom/apps"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "pulseaudio", "battery"],

    "custom/melt": {
        "format": "Melt Desktop",
        "tooltip": false
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
    "custom/apps": {
        "format": "{}",
        "return-type": "json",
        "exec": "cat /tmp/melt_windows.json",
        "interval": 1,
        "tooltip": false
    },
    "clock": {
        "format": "{:%I:%M %p  |  %B %d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
        "format": "CPU: {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "RAM: {}%"
    },
    "pulseaudio": {
        "format": "VOL: {volume}%",
        "format-muted": "VOL: Muted"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "BAT: {capacity}%",
        "format-charging": "CHG: {capacity}%"
    }
}
