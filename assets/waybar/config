{
    "layer": "top",
    "position": "top",
    "height": 40,
    "width": 10000,
    "exclusive": true,
    "margin-top": 8,
    "margin-left": 16,
    "margin-right": 16,
    "spacing": 10,
    "modules-left": ["custom/melt", "custom/apps", "cpu", "memory"],
    "modules-center": ["clock"],
    "modules-right": ["network", "pulseaudio", "battery"],

    "custom/melt": {
        "format": "Melt Desktop",
        "tooltip": false
    },
    "custom/apps": {
        "format": "{}",
        "return-type": "json",
        "exec": "cat /tmp/melt_windows.json",
        "interval": 1,
        "tooltip": false
    },
    "clock": {
        "format": "TIME: {:%H:%M} | DATE: {:%b %d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
        "format": "CPU: {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "RAM: {}%"
    },
    "network": {
        "format-wifi": "NET: {essid}",
        "format-ethernet": "NET: Wired",
        "format-disconnected": "NET: Offline"
    },
    "pulseaudio": {
        "format": "VOL: {volume}%",
        "format-muted": "VOL: Muted"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "BAT: {capacity}%",
        "format-charging": "CHG: {capacity}%"
    }
}
